# mock = deterministic fake chunks (dev/tests). live = BM25 on ingested chunks.jsonl.
RETRIEVER_MODE=mock

# fixture = tiny sample; full = production corpus path (Phase 2+).
DATASET_SOURCE=local
DATASET_PROFILE=fixture
DATASET_ID=fixture-v1
DATASET_FULL_PATH=data/raw/full
INGESTION_OUTPUT_PATH=data/processed
INGESTION_RAW_PATH=data/raw
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Used only when DATASET_SOURCE=arxiv.
ARXIV_QUERY=cat:cs.CL
ARXIV_MAX_RESULTS=5
ARXIV_TOPIC=arxiv
ARXIV_PERSIST_RAW=false

# Used only when DATASET_SOURCE=huggingface (pip install -e ".[dev]" or .[hf]).
HF_PRESET=qasper
HF_SPLIT=train
HF_MAX_ROWS=20
HF_QASPER_REVISION=refs/convert/parquet
HF_SCIFACT_PARQUET_GLOB=hf://datasets/allenai/scifact@refs/convert/parquet/corpus/train/*.parquet
