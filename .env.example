# mock = deterministic fake chunks (dev/tests). live = BM25 on ingested chunks.jsonl.
RETRIEVER_MODE=mock

# fixture = tiny sample; full = production corpus path (Phase 2+).
DATASET_SOURCE=local
DATASET_PROFILE=fixture
DATASET_ID=fixture-v1
DATASET_FULL_PATH=data/raw/full
INGESTION_OUTPUT_PATH=data/processed
INGESTION_RAW_PATH=data/raw
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Used only when DATASET_SOURCE=arxiv.
ARXIV_QUERY=cat:cs.CL
ARXIV_MAX_RESULTS=5
ARXIV_TOPIC=arxiv
ARXIV_PERSIST_RAW=false
# Full PDF download + PyMuPDF text extraction during arxiv ingest and on-demand fetches
ARXIV_FETCH_FULL_PDF=true
ARXIV_PDF_MAX_BYTES=25000000
ARXIV_PDF_MAX_EXTRACT_CHARS=1500000

# arXiv keyword discovery (API: arxiv_discovery=true; Gradio "Search arXiv")
ARXIV_DISCOVERY_MAX_RESULTS=5
ARXIV_DISCOVERY_TOPIC=arxiv-discovery
ARXIV_DISCOVERY_USE_FULL_PDF=true

# Used only when DATASET_SOURCE=huggingface (pip install -e ".[dev]" or .[hf]).
HF_PRESET=qasper
HF_SPLIT=train
HF_MAX_ROWS=20
HF_QASPER_REVISION=refs/convert/parquet
HF_SCIFACT_PARQUET_GLOB=hf://datasets/allenai/scifact@refs/convert/parquet/corpus/train/*.parquet

# Phase 4 answer generation + eval.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_OUTPUT_TOKENS=500
ANSWER_TOP_K=5
ANSWER_TEMPERATURE=0.2

# Multi-hop RAG (second retrieval when first hop is weak)
RAG_MULTI_HOP=true
RAG_MAX_HOPS=2
# RAG_HOP1_TOP_K=8
RAG_HOP2_TOP_K=12
RAG_EVIDENCE_MIN_CHUNKS=2
RAG_EVIDENCE_MIN_MAX_SCORE=0.15
RAG_EVIDENCE_MIN_MEAN_SCORE=0.05
EVAL_QUESTIONS_PATH=eval/questions/frozen_questions.jsonl
EVAL_RESULTS_DIR=eval/results

# Retrieval tuning (live mode). Hybrid is default; requires pip install -e ".[semantic]" for embeddings + rerank.
RETRIEVAL_PIPELINE=hybrid
RETRIEVAL_CANDIDATE_MULTIPLIER=4
RETRIEVAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
RETRIEVAL_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_RERANKER=cross_encoder
RETRIEVAL_RERANK_MAX_PAIRS=32

# LLM reliability
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120

# API rate limits (POST /ask, /ask/stream)
RATE_LIMIT_ENABLED=false
API_RATE_LIMIT_PER_MINUTE=90

# Gradio UI (scisynth-ui)
UI_PORT=7860
